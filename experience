目录扫描

gobuster扫描

# 基础扫描：指定目标URL、字典，探测目录

gobuster dir -u http://example.com/ -w /usr/share/wordlists/dirb/common.txt

# 常用参数： # -x：指定文件扩展名（如php,html，探测特定文件）

gobuster dir -u http://example.com/ -w /usr/share/wordlists/dirb/common.txt -x php,html

# -t：线程数（默认10，最大50） gobuster dir -u http://example.com/ -w /usr/share/wordlists/rockyou.txt -t 20

# -k：跳过SSL证书验证（针对HTTPS目标）

gobuster dir -u https://example.com/ -w common.txt -k #

-o：保存结果到文件 gobuster dir -u http://example.com/ -w common.txt -o scan_results.txt




dirsearch扫描

# 基础扫描：指定目标URL，默认字典

python3 dirsearch.py -u http://example.com/

# 常用参数： # -e：指定扩展名（如php,zip）

python3 dirsearch.py -u http://example.com/ -e php,zip

# -w：使用自定义字典

python3 dirsearch.py -u http://example.com/ -w /usr/share/wordlists/dirb/big.txt

# -r：递归扫描（进入子目录后继续扫描）

python3 dirsearch.py -u http://example.com/ -r

# -p：设置代理（如Burp Suite代理）

python3 dirsearch.py -u http://example.com/ -p 127.0.0.1:8080

# --delay：请求延迟（秒，避免被防火墙拦截）

python3 dirsearch.py -u http://example.com/ --delay 1

ffuf
# 基础扫描：用字典替换URL中的"FUZZ"
ffuf -u http://example.com/FUZZ -w /usr/share/wordlists/dirb/common.txt

# 常用参数：
# -e：指定扩展名（如-e .php,.html）
ffuf -u http://example.com/FUZZ -w common.txt -e .php,.html

# -t：线程数（默认40，最大不限，需谨慎）
ffuf -u http://example.com/FUZZ -w common.txt -t 50

# -mc：只显示指定状态码的结果（如200,301,403）
ffuf -u http://example.com/FUZZ -w common.txt -mc 200,301

# -o：保存结果为JSON格式
ffuf -u http://example.com/FUZZ -w common.txt -o ffuf_results.json
